{
  "name": "ai-content-repurposing-engine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite --host 127.0.0.1 --port 5173",
    "client:ai-preview": "vite --config vite.ai-preview.config.cjs --configLoader native",
    "dev:ai-preview": "concurrently \"npm run server\" \"npm run client:ai-preview\"",
    "server": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "start": "node server/index.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "openai": "^5.10.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0"
  }
}
